# Frontend .gitignore

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies
node_modules/
bower_components/

# Build outputs
dist/
dist-ssr/
build/
*.local

# Environment variables
.env
.env.local
.env.*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Lock files (optional - choose based on your package manager)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# OS generated files
.DS_Store
Thumbs.db

# Temporary files
*~
*.tmp
*.temp

# Coverage
coverage/
.nyc_output/

# Cache
.cache/
.parcel-cache/

# IDE
*.code-workspace