# 数据库配置
DATABASE_URL=sqlite:///./data/nasgallery.db

# 应用配置
APP_NAME=NasGallery API
APP_VERSION=0.1.0
DEBUG=True

# 路径配置
IMAGES_DIR=../data/images
CACHE_DIR=./data/tmp/cache

# 扫描配置
SCAN_INTERVAL=3600

# JWT配置
SECRET_KEY=nasgallery-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 管理员配置
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@nasgallery.com
ADMIN_PASSWORD=admin123