# NasGallery 生产环境配置文件
# 复制此文件为 .env 并根据实际情况修改

# ==================== 数据库配置 ====================
# SQLite 数据库路径（容器内路径）
DATABASE_URL=sqlite:///./data/nasgallery.db

# ==================== 应用配置 ====================
# 应用名称
APP_NAME=NasGallery API
# 应用版本
APP_VERSION=0.1.0
# 调试模式（生产环境必须设置为 False）
DEBUG=False

# ==================== 路径配置 ====================
# 图片目录（CBZ文件存放位置）
IMAGES_DIR=/app/data/images
# 缓存目录
CACHE_DIR=/app/data/tmp/cache
# 封面目录
COVERS_DIR=/app/data/tmp/covers

# ==================== 图片子目录配置 ====================
# 机构目录（按机构分类）
ORG_DIR=/app/data/images/org
# 模特目录（按模特分类）
MODEL_DIR=/app/data/images/model
# Cosplayer 目录（按 Cosplayer 分类）
COSPLAYER_DIR=/app/data/images/cosplayer
# 角色目录（按角色分类）
CHARACTER_DIR=/app/data/images/character

# ==================== JWT 配置 ====================
# 生产环境必须修改此密钥！
# 建议使用：openssl rand -hex 32 生成一个安全的密钥
SECRET_KEY=nasgallery-secret-key-change-in-production
# JWT 算法
ALGORITHM=HS256
# 访问令牌过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7天

# ==================== 扫描配置 ====================
# 扫描间隔（秒）
SCAN_INTERVAL=3600

# ==================== 标签配置 ====================
# 标签关键字（逗号分隔）
TAG_KEYWORDS=风景,人像,动漫,CG,厚涂,油画,漫画,水彩,国画

# ==================== CORS 配置 ====================
# 允许的源（生产环境应限制为实际域名）
# 多个源用逗号分隔
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ==================== 管理员配置 ====================
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@nasgallery.com
ADMIN_PASSWORD=changeme123
